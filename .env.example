# ─── Telegram MTProto ────────────────────────────────────────────
API_ID=YOUR_API_ID
API_HASH=YOUR_API_HASH
# String session gerada pelo script generate_session.py
# Deixe vazio para usar sessão em arquivo (sessions/)
STRING_SESSION=

# ─── Conta suporte ───────────────────────────────────────────────
PHONE_NUMBER=YOUR_PHONE_NUMBER
# Senha 2FA (deixe vazio se não tiver)
TWO_FA_PASSWORD=

# ─── API interna de controle ──────────────────────────────────────
INTERNAL_API_TOKEN=CHANGE_ME_TO_A_SECURE_RANDOM_TOKEN

# ─── Modos operacionais ──────────────────────────────────────────
DRY_RUN=true
READ_ONLY=false

# ─── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_PER_SECOND=1
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=300
RATE_LIMIT_DAILY_MAX=5000
RATE_LIMIT_PER_CHAT_MINUTE=5

# ─── Segurança ───────────────────────────────────────────────────
# IDs de chat permitidos (vazio = todos permitidos, exceto bloqueados)
ALLOWED_CHAT_IDS=
# IDs de chat bloqueados
BLOCKED_CHAT_IDS=
# Conta de controle — dono do userbot
OWNER_USER_ID=YOUR_OWNER_USER_ID

# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/hermes-userbot.log

# ─── Plugins ──────────────────────────────────────────────────────
# Ordem de carregamento dos plugins (vazio = todos em ordem alfabética)
PLUGINS_INCLUDE=
PLUGINS_EXCLUDE=