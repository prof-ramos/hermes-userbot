# ─── Telegram MTProto ────────────────────────────────────────────
TELEGRAM_API_ID=YOUR_API_ID
TELEGRAM_API_HASH=YOUR_API_HASH
# String session gerada pelo script generate_session.py
# Deixe vazio para usar sessão em arquivo (sessions/)
TELEGRAM_STRING_SESSION=
TELEGRAM_PHONE_NUMBER=YOUR_PHONE_NUMBER
# Senha 2FA (deixe vazio se não tiver)
TELEGRAM_TWO_FA_PASSWORD=*** ─── Segurança ───────────────────────────────────────────────────
# ID do dono da conta suporte no Telegram (comente se não souber)
# SECURITY_OWNER_USER_ID=123456789
SECURITY_ALLOWED_CHAT_IDS=[]
SECURITY_BLOCKED_CHAT_IDS=[]

# ─── API interna de controle ──────────────────────────────────────
API_INTERNAL_API_TOKEN=*** ─── Modos operacionais ──────────────────────────────────────────
DRY_RUN=true
READ_ONLY=false

# ─── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_PER_SECOND=1
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=300
RATE_LIMIT_DAILY_MAX=5000
RATE_LIMIT_PER_CHAT_MINUTE=5

# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/hermes-userbot.log

# ─── Plugins ──────────────────────────────────────────────────────
PLUGINS_INCLUDE=[]
PLUGINS_EXCLUDE=[]